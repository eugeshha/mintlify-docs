{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "DevOps: от и до",
  "colors": {
    "primary": "#4f46e5",
    "light": "#6366f1",
    "dark": "#3730a3"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Справочник",
        "groups": [
          {
            "group": "Обзор",
            "pages": ["index"]
          },
          {
            "group": "Базовые основы",
            "pages": [
              "fundamentals/linux",
              "fundamentals/networking",
              "fundamentals/scripting",
              "fundamentals/git"
            ]
          },
          {
            "group": "Контейнеры",
            "pages": ["containers/docker"]
          },
          {
            "group": "CI/CD",
            "pages": ["cicd/overview", "cicd/gitlab-ci"]
          },
          {
            "group": "Kubernetes",
            "pages": [
              "kubernetes/overview",
              "kubernetes/probes",
              "kubernetes/volumes",
              "kubernetes/ingress-networking",
              "kubernetes/helm"
            ]
          },
          {
            "group": "Infrastructure as Code",
            "pages": ["iac/terraform", "iac/ansible"]
          },
          {
            "group": "Облака",
            "pages": ["cloud/overview"]
          },
          {
            "group": "Наблюдаемость",
            "pages": [
              "observability/prometheus-grafana",
              "observability/logging"
            ]
          },
          {
            "group": "Безопасность",
            "pages": ["security/overview"]
          }
        ]
      },
      {
        "tab": "Практика",
        "groups": [
          {
            "group": "Kubernetes: домашние задания",
            "pages": ["kubernetes/homework"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Mintlify Docs",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": []
  },
  "contextual": { "options": ["copy", "view", "chatgpt", "claude", "cursor", "vscode"] },
  "footer": { "socials": {} }
}
